                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p><material>Limestone</material> <objectType>altar</objectType> with 3 very shallow compartments
                                        (overall <dimensions>
                                            <width>1.21</width>
                                            <height>0.22</height>
                                            <depth>0.45</depth>
                                        </dimensions>; 
                                        compartments from left to right:
                                        <dimensions><width>0.32</width> <depth>0.37</depth></dimensions>,
                                        <dimensions><width>0.34</width> <depth>0.37</depth></dimensions>,
                                        <dimensions><width>0.33</width> <depth>0.37</depth></dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on front face under the upper edge, in correspondence with each compartment.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.03</height>; small omicron, very short right stroke of pi, slanting sigma, small and flat loop of phi.</handNote>
                        </handDesc>
                    </physDesc>
