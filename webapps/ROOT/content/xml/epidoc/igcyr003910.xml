                <p><bibl><ptr target="#boardman-hayes1973"/>, n. <citedRange>F174</citedRange> (dr.)</bibl>;
                    <bibl><ptr target="#IGCyr"/> <citedRange>003910</citedRange></bibl>.</p>           
