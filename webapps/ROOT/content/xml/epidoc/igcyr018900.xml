                <msDesc>
                    <msIdentifier/>
                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>White <material>marble</material> oblong <objectType>block</objectType> with a disk in relief on the inscrideb face, broken at left and right
                                        (<dimensions>
                                            <width>0.71</width>
                                            <height>0.29</height>
                                            <depth>0.20</depth>
                                        </dimensions>); Laronde also noticed a moulding on the opposite side.</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on front face which was decorated with disks (perhaps symbolizing shields), of which only one is preserved at right. The text was inscribed in the intervals, part A (ll. 1-2) in columns overlapping the disks if necessary, part B (l. 3) with one word in each interval (Rosamilia's suggestion).</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height min="0.035" max="0.038">0.035-0.038</height>; slight serifs, pi with slightly projecting upper bar, rho with very small loop, non-slanting sigma, horse-shoe omega.</handNote>
                        </handDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>Unknown</origPlace>
                            <origDate evidence="lettering" notBefore="-0150" notAfter="-0101" precision="low">Perhaps second half of second century BC</origDate>
                        </origin>
                        
                            
                                <provenance type="found" when="1928">
                                    <p>Found in 1928 at
                                        <placeName type="ancientFindspot" ref="https://www.slsgazetteer.org/909" key="http://pleiades.stoa.org/places/373778">Cyrene</placeName>: 
                                        <rs type="monuList" ref="https://www.slsgazetteer.org/1228">Sanctuary of Apollo</rs>, re-used in the late stairs in front of 
                                        <rs type="monuList" ref="https://www.slsgazetteer.org/1033">Temple of Apollo</rs>.
                                   </p>
                                </provenance>
                        <provenance type="observed" notAfter="1980" resp="Laronde">
                            <p>Seen by Laronde for the last time in 1980 placed on the exedra in front of Apollo's temple in the <rs type="monuList" ref="https://www.slsgazetteer.org/1228">Sanctuary of Apollo</rs>.</p>
                        </provenance>
                                <provenance type="observed" resp="Paci">
                                    <p>Seen at an unknown date by G. Paci, probably at the same place.</p>
                                </provenance>
                        <provenance type="not-observed">
