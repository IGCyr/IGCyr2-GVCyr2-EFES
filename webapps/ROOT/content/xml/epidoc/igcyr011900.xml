                    <lb n="2"/><w lemma="ἔξειμι"><supplied reason="lost">ἐξιὸ</supplied>ν</w> <w lemma="βουθυσία">βουθυ<supplied reason="lost">σιᾶν</supplied></w> 
                        <w lemma="εἰμι"><supplied reason="lost">ἠσσᾶν</supplied></w> 
                    <lb n="3"/><gap reason="lost" extent="unknown" unit="character"/>
                        <num type="total" atLeast="21.2"><measure type="currency" unit="drachma">
