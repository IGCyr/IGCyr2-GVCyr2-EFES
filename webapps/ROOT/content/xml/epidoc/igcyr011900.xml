                                    <num value="0.2"><g type="cyrnum">&gt;</g></num></measure></num></measure></num> <g type="punct">⋮</g>, <w lemma="λοιπός">λ<supplied reason="lost">οιπὸν</supplied></w> <gap reason="lost" extent="unknown" unit="character"/>
                    <lb n="4"/><gap reason="lost" extent="unknown" unit="character"/> 
                    <num type="total" atLeast="28.4"><measure type="currency" unit="drachma">
                            <w lemma="μνᾶ"><supplied reason="lost"><expan><abbr>μ</abbr><ex>ναῖ</ex></expan></supplied></w><gap reason="lost" extent="unknown" unit="character"/>
                            <num type="total" atLeast="28.4"><measure type="currency" unit="drachma">
                                    <num value="20"><g type="cyrnum">Χ</g></num>
                                    <num value="4"><g type="cyrnum">𐅠</g></num>
                                    <num value="4"><g type="cyrnum">𐅠</g></num>
                                    <num value="0.2"><g type="cyrnum">&gt;</g></num>
                                    <num value="0.2"><g type="cyrnum">&gt;</g></num></measure></num></measure></num><gap reason="lost" extent="unknown" unit="character"/>. 
                        <w lemma="παρόρεγμα"><supplied reason="lost">Παρόρεγ</supplied><lb n="5" break="no"/><supplied reason="lost">μα</supplied></w> <rs type="office" key="damiergos"><w lemma="δαμιεργός"><supplied reason="lost">δ</supplied>αμιε<supplied reason="lost">ργοῖς</supplied></w></rs>
                        <supplied reason="lost"><num type="total" value="300"><measure type="currency" unit="drachma">
                            <w lemma="μνᾶ"><expan><abbr>μ</abbr><ex>ναῖ</ex></expan></w>
                            <num type="total" value="3"><measure type="currency" unit="mna">
