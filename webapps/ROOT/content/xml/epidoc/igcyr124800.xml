        <body><div type="bibliography">
                
            <p>Not published before <bibl><ptr target="#IGCyr"/> <citedRange>124800</citedRange></bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                <ab>
                    <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/><orig>μο<choice><unclear>ι</unclear><unclear>τ</unclear></choice></orig><gap reason="lost" extent="unknown" unit="character"/>
