                       <lb n="1"/><milestone unit="block" n="i"/><space quantity="0.6" unit="metre"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost" cert="low">2.75 metre</supplied>
                        <milestone unit="block" n="ii"/><persName type="divine" ref="#Kyrana"><name nymRef="#Κυράνα">Κυράνα</name></persName> 
                        <space quantity="0.195" unit="metre"/> <persName type="divine" ref="#Apollo"><name nymRef="#Ἀπόλλων">Ἀπόλλων</name></persName> <gap reason="lost" extent="unknown" unit="character"/> <supplied reason="lost" cert="low">0.75 metre</supplied>
                        <milestone unit="block" n="iii"/><del rend="erasure"><add place="overstrike"><ref type="inscription" target="https://ircyr2020.inslib.kcl.ac.uk/en/inscriptions/C.121.html">IRCyr2020 C.121</ref></add></del>
                        <space quantity="0.34" unit="metre"/> <persName type="divine" ref="#Libya"><name nymRef="#Λιβύα">Λιβύα</name></persName> <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost" cert="low">1.75 metre</supplied>
