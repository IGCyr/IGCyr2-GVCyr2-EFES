                            <supportDesc>
                                <support>
                                    <p>Fragment of a white black-veined <material>marble</material> circular <objectType>basin</objectType>,
                                        of a rather deep shape; the outer face is sculpted so as to form a folded cloth or a sea shell
                                        (<dimensions>
                                            <width atLeast="0.29">0.29</width>
                                            <height atLeast="0.20">0.20</height>
                                            <depth/>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> a) on the rim (high 0.035), b) below on the inner face, 
                                    both to be read from the centre.</layout> 
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.032</height>; no serifs, deeply cut, broadly open alpha, oblique bars of kappa not intersecting with the hasta.</handNote>
                        </handDesc>
                    </physDesc>
