                    <lb n="4"/><milestone unit="fragment" n="a"/>ἢ τῶ<supplied reason="lost">ν</supplied> <gap reason="lost" atLeast="22" atMost="26" unit="character"/><milestone unit="fragment" n="b"/><gap reason="lost" extent="unknown" unit="character"/>
