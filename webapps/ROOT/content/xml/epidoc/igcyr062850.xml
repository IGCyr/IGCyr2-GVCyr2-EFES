                    <bibl><ptr target="#cdl2000a"/><citedRange/></bibl>, whence <bibl><ptr target="#SEG"/>, <citedRange>50.1639.B.IV</citedRange></bibl>;
                    <bibl><ptr target="#IGCyr"/> <citedRange>062850</citedRange></bibl>;
                    <bibl><ptr target="#rosamilia2023"/>, pp. <citedRange>240-243</citedRange>, number 4, document VII (text)</bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
