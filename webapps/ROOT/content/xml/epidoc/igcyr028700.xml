                    <lb n="4"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63329"><name nymRef="#Αὐτοκλῆς">Αὐτοκλῆ<supplied reason="lost">ς</supplied></name>
                    <lb n="5"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63062"><name type="patronymic" nymRef="#Ἀρίσταρχος">Ἀριστάρχ<supplied reason="lost">ω</supplied></name></persName></persName>,
                    <lb n="6"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65694"><name nymRef="#Σώσανδρος">Σώσανδρ<supplied reason="lost">ος</supplied></name>
                    <lb n="7"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63329"><name type="patronymic" nymRef="#Αὐτοκλῆς">Αὐτοκλεῦ<supplied reason="lost">ς</supplied></name></persName></persName>,
                    <lb n="8"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65438"><name nymRef="#Πρᾶξις">Πρᾶξις</name>
                    <lb n="9"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65694"><name type="patronymic" nymRef="#Σώσανδρος">Σωσάνδρω</name></persName></persName>.
                    <lb n="10"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65437"><name nymRef="#Πρᾶξις">Πρᾶξις</name>
                    <lb n="11"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65094"><name type="patronymic" nymRef="#Νέων">Νέωνος</name></persName></persName>,
                    <lb n="12"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65095"><name nymRef="#Νέων">Νέων</name>
                    <lb n="13"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65094"><name type="patronymic" nymRef="#Νέων">Νέωνος</name></persName></persName>.

