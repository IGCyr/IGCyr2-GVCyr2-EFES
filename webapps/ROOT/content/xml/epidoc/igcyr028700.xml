                    <lb n="2"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-64270"><name nymRef="#Θράσος"><unclear>Θ</unclear>ράσος</name> <orig>ασ</orig>
