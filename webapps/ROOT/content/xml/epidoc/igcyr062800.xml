                    <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/><orig><unclear>ε</unclear></orig> δὲ <w part="I">α<unclear>ὐ</unclear><lb n="3" break="no"/><supplied reason="lost">τ</supplied></w><gap reason="lost" extent="unknown" unit="character"/><orig><unclear>κ</unclear>εν</orig>
