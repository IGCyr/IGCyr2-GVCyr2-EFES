                        <lb n="7"/><persName type="attested" key=""><name nymRef="#_ρος"><gap reason="lost" extent="unknown" unit="character"/><gap reason="illegible" quantity="1" unit="character"/><seg part="F">ρος</seg></name>
                        <lb n="8"/><persName type="attested" key=""><name nymRef="#_κράτης" type="patronymic"><gap reason="lost" extent="unknown" unit="character"/><seg part="F"><supplied reason="lost">κρ</supplied>άτευς</seg></name></persName></persName>
                    </ab>
                </div>
                <div type="textpart" subtype="column" n="e">
                    <ab>
                        <lb n="9"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63355"><name nymRef="#Βαῖος">Βαῖος</name>
                        <lb n="10"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-64856"><name type="patronymic" nymRef="#Λυσανίας">Λυσανία</name></persName></persName>
                    </ab>
                </div>
                <div type="textpart" subtype="column" n="f">
                    <ab>
                        <lb n="11"/><persName type="attested" key=""><name><seg part="I"><choice><unclear>Γ</unclear><unclear>Π</unclear></choice></seg><gap reason="lost" extent="unknown" unit="character"/></name>
                        <lb n="12"/><persName type="attested" key=""><name nymRef="#Θ_" type="patronymic"><seg part="I">Θ</seg><gap reason="lost" extent="unknown" unit="character"/></name></persName></persName>
                    </ab>
                </div>
                <div type="textpart" subtype="text">
                    <ab>
                        <lb n="13"/><w lemma="τελεσφορέω"><supplied reason="lost">τελεσφο</supplied>ρέντε<supplied reason="lost">ς</supplied></w>
                        <lb n="13a"/><gap reason="lost" extent="unknown" unit="line"/>
                    </ab>
