        <body><div type="bibliography">
                
                <p><bibl><ptr target="#SECir"/>, <citedRange>144</citedRange> (no image)</bibl>;
                    <bibl><ptr target="#IGCyr"/> <citedRange>099200</citedRange></bibl>.</p>
            <p>Cf. <bibl><ptr target="#rosamilia2023"/>, pp. <citedRange>196-197</citedRange> (typology)</bibl>.</p>
