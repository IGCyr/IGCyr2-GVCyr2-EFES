        <body><div type="bibliography">
                
                <p><bibl><ptr target="#fraser1958"/>, pp. 111-112, n. <citedRange>4</citedRange>, pl. XII, 4</bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>18.734</citedRange></bibl>; 
                    <bibl><ptr target="#fraser1972"/> II, p. <citedRange>191, footnote 85</citedRange></bibl>; 
                    <bibl><ptr target="#laronde1987"/>, p. <citedRange>417</citedRange></bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>38.1882</citedRange></bibl>;
                    <bibl><ptr target="#IGCyr"/> <citedRange>063300</citedRange></bibl>. 
                    Cf. <bibl><ptr target="#marquaille2003"/><citedRange/></bibl>, and 
                    <bibl><ptr target="#cdlBE"/>, <citedRange>2005.620</citedRange></bibl>, whence
                    <bibl><ptr target="#SEG"/>, <citedRange>53.2028</citedRange></bibl>;
                    <bibl><ptr target="#cigaina-vitale2017"/>, pp. <citedRange>93-96</citedRange></bibl>, whence
                    <bibl><ptr target="#SEG"/>, <citedRange>67.1480</citedRange></bibl>;
                    <bibl><ptr target="#rosamilia2018"/>, pp. <citedRange>281-282</citedRange></bibl>;
                    <bibl><ptr target="#rosamilia2023"/>, p. <citedRange>355</citedRange>, number 78</bibl> (text).</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                <ab>
                    <lb n="1"/><persName type="attested" key=""><name nymRef="#Πέλοψ"><milestone unit="fragment" n="a"/>Πέλ<milestone unit="fragment" n="b"/><unclear>ο</unclear>πα</name> <persName type="attested"><name nymRef="#Πέλοψ" type="patronymic">Πέλο<supplied reason="lost">πος</supplied></name></persName></persName>
                            <supplied reason="lost" cert="low">τὸν <rs type="office" key="libyarch"><w lemma="λιβυάρχας">λιβυάρχαν</w></rs> <placeName type="ethnic" nymRef="#Κυραναῖος">Κυραναῖοι</placeName></supplied>
                    <lb n="2"/><w lemma="ἀνατίθημι"><milestone unit="fragment" n="a"/>ἀν<unclear>έ</unclear><milestone unit="fragment" n="b"/>θηκαν</w> <w lemma="ἀρετά">ἀρε<supplied reason="lost">τᾶς</supplied></w> <w lemma="ἕνεκα"><supplied reason="lost">ἕνεκα</supplied></w> <supplied reason="lost">καὶ</supplied> <w lemma="εὔνοια"><supplied reason="lost">εὐνοίας</supplied></w> <supplied reason="lost">τᾶς</supplied> <w lemma="ἐς"><supplied reason="lost">ἐς</supplied></w> 
                    <persName type="ruler" key="Ptolemy III and Berenice II"><w lemma="βασιλεύς"><supplied reason="lost">βασιλῆ</supplied></w>
                    <lb n="3"/><persName type="ruler" key="Ptolemy III"><name nymRef="#Πτολεμαῖος"><supplied reason="lost">Πτο</supplied>λεμαῖον</name></persName> 
                            κα<supplied reason="lost">ὶ <w lemma="βασίλισσα">βασίλισσαν</w></supplied> 
                        <persName type="ruler" key="Berenice II"><name nymRef="#Βερενίκα"><supplied reason="lost">Βερενίκαν</supplied></name></persName> 
