                <msDesc>
                    <msIdentifier/>
                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>Two out of six blocks of greyish <material>marble</material>, forming together a <objectType>semi-circular exedra</objectType>, with holes and footprints 
                                        on upper sides: A is the leftmost block and was in 1983 still attached to the adjacent block (not inscribed) on the right; B is a loose angle, prepared for 
                                        attachment to another block on its right and broken off at left and bottom;
                                        grey <material>marble</material>
                                        (A: <dimensions n="A">
                                            <width>0.74</width>
                                            <height>0.325</height>
                                            <depth>0.57</depth>
                                            <dim type="arc" max="0.75">-0.75</dim>
                                        </dimensions> B:
                                            <dimensions n="B">
                                                <dim type="chord">0.36</dim>
                                                <height atLeast="0.29">0.29</height>
                                                <depth atLeast="0.45">0.45</depth>  
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs>: A on loose side, looking to the lane; B on concave side, facing the visitor.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>A: <height n="A">0.04</height>; B: <height n="B">0.033</height>; homogenous hand, careful lettering.</handNote>
                        </handDesc>
                    </physDesc>
                    <history>
