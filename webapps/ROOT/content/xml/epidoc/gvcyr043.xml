                    <div type="textpart" subtype="text">
                     <ab>
                        <lb n="1"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-61576"><name nymRef="#Ἀφροδισία">Ἀφροδεισία</name> ἡ καὶ <name type="surname" nymRef="#Πτολεμαΐς">Πτ<supplied reason="lost">ο</supplied><unclear>λ</unclear>εμαΐς</name></persName> <date dur="P2Y"><w lemma="ἔτος">ἐτῶν</w> <num type="cardinal" value="2"><w lemma="δύο">δύο</w></num></date> 
                         <w lemma="ἐνθάδε">ἐνθάδε</w> <w lemma="κεῖμαι">κε<space quantity="1" unit="character"/>ῖται</w>.
                        <lb n="2"/><w lemma="οὗτος">ταύτης</w> ὁ <w lemma="πατήρ">πατὴρ</w> <w lemma="ἀπαγορεύω">ἀπα<unclear>γο</unclear>ρεύει</w> <w lemma="οὗτος">ταῦτα</w> <w lemma="λέγω">λέγων</w>· <w lemma="ὅς1" type="relative">ὃς</w> <w lemma="ἄν">ἂν</w> <w lemma="ἀνοίγω">ἀνύξῃ</w>
                        <lb n="3"/><unclear>τ</unclear>ὸ <w lemma="λαρνάκιον">λαρνάκιον</w> <w lemma="οὗτος">τοῦτό</w> <w lemma="ποτέ">πο<unclear/>τ<supplied reason="lost">ε</supplied></w> καὶ 
                        <w lemma="θάπτω">θάψῃ</w> <w lemma="τις">τινά</w> <w lemma="εἰσφέρω">εἴσοισει</w> τῷ
                        <lb n="4"/><w lemma="ἱερός">ἱερωτάτῳ</w> <w lemma="ταμεῖον">ταμείῳ</w> <w lemma="δηνάριον">δηνάρια</w> 
                        <num type="cardinal" value="500"><w lemma="πεντακόσιοι">πε<unclear>ν</unclear>τα<supplied reason="lost">κό</supplied>σ<unclear>ι</unclear>α</w></num>. <g type="leaf">❧</g>  
                     </ab>
                    </div>
                    <div type="textpart" subtype="verse">
