                    <lb n="3"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-66135"><name nymRef="#Χαιράδας">Χαιράδα</name> <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-62664"><name nymRef="#Αἰσχίνας" type="patronymic">Αἰσχίνα</name></persName></persName>,
                    <lb n="4"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-62591"><name nymRef="#Ἇγις"><supplied reason="lost">Ἅ</supplied>γιος</name> <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63520"><name nymRef="#Δεξίδαμος" type="patronymic">Δεξιδάμω</name></persName></persName>,
                    <lb n="5"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65407"><name nymRef="#Πόλων"><supplied reason="lost">Π</supplied>όλωνος</name> <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63926"><name nymRef="#Εὐφράνωρ" type="patronymic">Εὐφράνο<lb n="6" break="no"/><supplied reason="lost">ρ</supplied>ος</name></persName></persName>, τῶ <persName type="divine" ref="#Apollo"><name nymRef="#Ἀπόλλων">Ἀπόλλωνος</name></persName>
                    <lb n="7"/><rs type="office" key="eponymous priest"><w lemma="ἱαριτεύω"><supplied reason="lost">ἱ</supplied>αριτεύοντος</w></rs> <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-64963"><name nymRef="#Μελάνιππος">Μελα<lb n="8" break="no"/><supplied reason="lost">ν</supplied>ίππω</name> <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63059"><name nymRef="#Ἀρίστανδρος" type="patronymic">Ἀριστάνδρω</name></persName></persName>.
                    <lb n="9"/><w lemma="καρπός"><supplied reason="lost">Καρ</supplied>πὸς</w> <w lemma="τιμάω">ἐτιμάθη</w>· <w lemma="κριθά">κ<lb n="10" break="no"/><supplied reason="lost">ρι</supplied>θαὶ</w> <w>ἀν</w> <measure type="currency" unit="drachma">
                        <num value="1.6"><g type="cyrnum">Ζ</g>
