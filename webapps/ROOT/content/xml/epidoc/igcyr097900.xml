                    <ab>
                    <lb n="1"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-64671"><name nymRef="#Κλεύθεμις">Κλεύθεμις</name>
