                    <lb n="4"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65903"><name type="patronymic" nymRef="#Φιλέγγυος">Φιλεγγύω</name></persName></persName>
