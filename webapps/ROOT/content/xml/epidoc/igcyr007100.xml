                <ab>
                    <lb n="1"/><handShift new="#m1"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63028"><name nymRef="#Ἀργεῖος">Ἀργεῖος</name> 
                    <lb n="2"/><handShift new="#m2"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63511"><name type="patronymic" nymRef="#Δεῖνις">Δένιος</name></persName></persName>
                    <lb n="3"/><handShift new="#m2"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63028"><name nymRef="#Ἀργεῖος">Ἀργεῖος</name>
                    <lb n="4"/><handShift new="#m1"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63511"><name type="patronymic" nymRef="#Δεῖνις">Δείνιος</name></persName></persName>	 
