                   <w lemma="πρό">πρὸ</w> γὰρ <unclear>βαρ</unclear><supplied reason="lost">υ</supplied></seg>
                    <seg met="+--|+±"><gap reason="lost" extent="unknown" unit="character"/></seg></l>
               
