              <l n="2" met="pentameter"><seg real="+--|++|+|+--|+--|-">
                  <lb n="7"/><space quantity="3" unit="character"/> <w lemma="κλύω">ἔκλυες</w>, 
                  <w lemma="ὅς1" type="relative">ὃς</w> <w lemma="τέχνη">τέχνην</w> <w lemma="μέγας">μέζον'</w> <w lemma="ἐπαγλαΐζω">ἐπηγλάϊσα</w> <space quantity="3" unit="character"/></seg></l>
           </lg>
           <lg met="elegiac couplet">
              <l n="3" met="hexameter"><seg real="+--|++|+--|+--|+--|+-">
                  <lb n="8"/><w lemma="ἦθος">ἤθεσι</w>, <placeName type="city" nymRef="#Κυράνα">Κυρήνηι</placeName> 
                  <w lemma="βασιλήιος">βασιλήϊον</w> <w lemma="ὅς1" type="relative">ὃς</w>  <w lemma="μέγας">μέγα</w> <w lemma="δῶρον">δῶρον</w></seg></l>
               
              <l n="4" met="pentameter"><seg real="+--|+--|+|+--|+--|+"> 
                  <lb n="9"/><space quantity="3" unit="character"/><w lemma="πατρίς">πατρίδι</w>, 
                  τὰς <w lemma="μάκαρ">μακάρων</w> <w lemma="εἰκών">εἰκόνας</w>, <w lemma="ἄγω">ἠγαγόμην</w> <space quantity="3" unit="character"/></seg></l>
           </lg>
                
           <lg met="elegiac couplet">
              <l n="5" met="hexameter"><seg real="++|++|+--|+--|+--|++">
                  <lb n="10"/><w lemma="ὅς1" type="relative">τῷ</w> καὶ <rs type="office" key="boule"><w lemma="βουλευτής">βουλευτῇσι</w></rs> 
                  <w lemma="μετατρέπω">μετέπρεπον</w>, <w lemma="ἐνθάδε">ἐνθάδε</w> <w lemma="κεῖμαι">κεῖμαι</w>.</seg></l>
               
              <l n="6" met="pentameter"><seg real="+--|+--|+|+--|+--|-">
                  <lb n="11"/><space quantity="3" unit="character"/><w lemma="λοίσθιος">λοίσθιον</w> οὐ 
                  <w lemma="τέκος">τεκέεσσ'</w> οὐδ' <w lemma="ἄλοχος">ἀλόχωι</w> <w lemma="δάκρυον">δάκρυον</w>, <space quantity="3" unit="character"/></seg></l>
           </lg>
                
           <lg met="elegiac couplet">
              <l n="7" met="hexameter"><seg real="++|+--|+--|+--|+--|++">
                  <lb n="12"/><persName type="attested"><name nymRef="#Εὐθυκλῆς">Εὐθυκλεῖ</name></persName> δὲ <w lemma="φίλος">φίλωι</w> <w lemma="ἐγώ">μοι</w> 
                      <w lemma="ἀδελφός">ἀδελφεῶι</w> <w lemma="ὅς1" type="relative">ὅς</w> <w lemma="ἐγώ">με</w> <w lemma="γενέθλη">γενέθληι</w></seg></l>
               
              <l n="8" met="pentameter"><seg real="++|+--|+|+--|+--|+">
                  <lb n="13"/><space quantity="3" unit="character"/> <w lemma="πρεσβεύω">πρεσβεύων</w>, τὰ <w lemma="πατήρ">πατρὸς</w> <w lemma="πᾶς">πάντ'</w> <w lemma="μογέω">ἐμόγησ'</w> <w lemma="ἐπί">ἐπ'</w> <w lemma="ἐγώ">ἐμοί</w>,
                  <space quantity="3" unit="character"/></seg></l>
           </lg>
                
