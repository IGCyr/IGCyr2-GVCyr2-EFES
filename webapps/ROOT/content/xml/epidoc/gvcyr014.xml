           <lb n="15a"/><gap reason="lost" extent="unknown" unit="line"/>
           </div>
            </div><div type="apparatus" xml:space="preserve">
            
                <p>
                    <app loc="14">
                            <lem resp="#jmr-bacchielli1996"><unclear>βαρ</unclear><supplied reason="lost">υ</supplied><gap reason="lost" extent="unknown" unit="character"/></lem>
                            <rdg resp="#jmr-bacchielli1996"><unclear>βαρ</unclear><supplied reason="lost">υκήδεϊ πότμῳ</supplied> <note>Peek's suggestion per epistulam</note></rdg> 
                        
                    </app>
                    <app loc="15">
                            <lem resp="#jmr-bacchielli1996"><gap quantity="8" unit="character" reason="lost" precision="low"/><orig><unclear>σ</unclear>ηρ<unclear>ιι</unclear></orig><gap extent="unknown" reason="lost" unit="character"/></lem>
                            <rdg resp="#jmr-bacchielli1996"><supplied reason="lost">χῶρον ἐ</supplied>ς ἡρώ<supplied reason="lost">ων ἤλυθον</supplied> 
