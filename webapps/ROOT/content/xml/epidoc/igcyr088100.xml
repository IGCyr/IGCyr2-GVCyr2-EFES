                    <lb n="1"/><w lemma="θεός"><supplied reason="lost">Θεοί</supplied></w>                    
                    <lb n="2"/><rs type="office" key="damiergos"><w lemma="δαμιεργέω"><supplied reason="lost">Δαμιεργέντων</supplied></w></rs> <gap reason="lost" atLeast="6" atMost="8" unit="character"/>
