                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on front face in two lines with varying spaces between letters in order to fill the whole width.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>Dimensions <height>unknown</height>; alpha with low bar, spoon-shaped zeta, smaller omicron, phi with small flattened loop, horseshoe-shaped omega.</handNote>
