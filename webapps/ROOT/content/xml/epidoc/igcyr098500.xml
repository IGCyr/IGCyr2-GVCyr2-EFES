                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p><material>Limestone</material> treasury now fully reconstructed, the facade of which has a Doric <objectType>frieze</objectType> with eight metopes (each <dimensions>
                                            <width>0.472</width>
                                            <height>0.61</height>
                                            <depth>0.63</depth>
                                        </dimensions>) above the <objectType>architrave</objectType> made of five adjacent blocks (each <dimensions>
                                            <width>1.56</width>
                                            <height>0.50</height>
                                            <depth precision="low">8.7</depth>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> a) on metopes ii to vii (vi and vii with text lost); b) on the architrave.</layout>
                            </layoutDesc>
                        </objectDesc>
                            <handDesc>
                            <handNote>a) <height atLeast="0.04" atMost="0.06">0.04-0.06</height>; b)<height atLeast="0.09" atMost="0.1">0.09-0.10</height>.</handNote>
                        </handDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>Findspot.</origPlace>
                            <origDate evidence="prosopography" notBefore="-0340" notAfter="-0330" precision="medium">Between 340 and 330 BC</origDate>
                        </origin>
                                <provenance type="found" notBefore="1928" notAfter="1929">
                                    <p>The first fragments were found in 1928, the others in 1929 at <placeName type="ancientFindspot" ref="https://www.slsgazetteer.org/909" key="http://pleiades.stoa.org/places/373778">Cyrene</placeName>:
                                        <rs type="monuList" ref="https://www.slsgazetteer.org/1228">Sanctuary of Apollo</rs>, in the excavations of the
                                        <rs type="monuList" ref="https://www.slsgazetteer.org/1042">Strategeion</rs>.
                                   </p>
                                </provenance>
                                <provenance type="observed" when="1983" resp="CDL">
                                    <p>Studied by C. Dobias-Lalou in 1983 in situ, replaced the restored <rs type="monuList" ref="https://www.slsgazetteer.org/1042">Strategeion</rs>.</p>
                                </provenance>
                        <provenance type="observed" when="2012" resp="#ER">
                            <p>Also studied by E. Rosamilia in 2012 on the restored monument in situ.</p>
                        </provenance>
