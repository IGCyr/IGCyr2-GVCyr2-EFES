                        <lb n="1"/><milestone unit="block" n="i"/><w lemma="τελεσφορέω"><supplied reason="lost">Τε</supplied><milestone unit="block" n="ii"/>λεσ<milestone unit="block" n="iii"/><supplied reason="lost">φο</supplied><milestone unit="block" n="iv"/><supplied reason="lost">ρέ</supplied>ν<milestone unit="block" n="v"/>τες</w> <milestone unit="block" n="vi"/>τῶι 
                        <milestone unit="block" n="vii"/><persName type="divine" ref="#A_"><name nymRef="#Ἀ_"><seg part="I">Ἀ</seg><gap reason="lost" atLeast="1" atMost="2" unit="character"/><milestone unit="block" n="viii"/><gap reason="lost" atLeast="2" atMost="3" unit="character"/><milestone unit="block" n="ix"/><supplied reason="lost">νι</supplied></name></persName>                    
                    </ab>
                </div>
