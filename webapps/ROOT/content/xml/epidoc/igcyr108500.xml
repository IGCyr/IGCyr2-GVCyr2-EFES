                        <lb n="7"/><persName type="attested" key=""><name nymRef="#Λυσ_" type="patronymic"><seg part="I">Λυσ</seg><gap reason="lost" atMost="6" unit="character"/></name></persName></persName>
                    </ab>
                </div>
