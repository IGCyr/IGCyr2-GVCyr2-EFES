        <body><div type="bibliography">
                
                <p><bibl><ptr target="#oliverioDAI2"/>, p. 113, n. <citedRange>97</citedRange>, fig. 53</bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>9.209</citedRange></bibl>; 
                    <bibl><ptr target="#IGCyr"/> <citedRange>025300</citedRange></bibl>.
