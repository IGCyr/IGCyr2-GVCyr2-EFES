                <p><app loc="1"><lem resp="#gallavotti1963 #CEG"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">ἀν</supplied><unclear>α</unclear>δήσας</lem>
                <rdg resp="#SECir #laronde1987"><gap reason="lost" extent="unknown" unit="character"/>αδήσας</rdg>
                <rdg resp="#peek1972"><supplied reason="lost">πολλάκις ἄλλος μὲν κεφαλὴν στεφάνοις ἀν</supplied>αδήσας</rdg>
                    <rdg resp="#rosamilia2023"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost" cert="low">κατ</supplied><unclear>α</unclear>δήσας</rdg>
                </app>
                    <app loc="2"><lem resp="#CEG"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost" cert="low">πατρί</supplied>δος</lem>
                    <rdg resp="#SECir #laronde1987 #rosamilia2023"><gap reason="lost" extent="unknown" unit="character"/><orig>δος</orig></rdg>
                    <rdg resp="#peek1972"><supplied reason="lost">νίκαις ηὔξησεν κῦδος ἑῆς πατρί</supplied>δος</rdg>
                    </app>
                    <app loc="3"><lem resp="#GVCyr #rosamilia2023"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">ἐνὶ δ</supplied>ώμασιν ἵππον</lem>
                        <rdg type="alternative" resp="#rosamilia2023"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">σ</supplied>ώμασιν ἵππον</rdg>
                        <rdg resp="#SECir #laronde1987 #CEG"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">δ</supplied>ώμασιν ἵππον</rdg>
                        <rdg resp="#peek1972"><supplied reason="lost">ἅρματα καλά τ' ἔχων θρέψας τ'ἐνὶ δ</supplied>ώμασιν ἵππον</rdg>
                    </app>
                    <app loc="4"><lem resp="#SECir #laronde1987 #CEG"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">Τ</supplied>ιμαγόρας δὲ ἀρετῆι</lem>
                        <rdg resp="#peek1972"><supplied reason="lost">ὠκυδρόμον, σφετέρηι Τ</supplied>ιμαγόρας δὲ ἀρετῆι·</rdg>
                    </app>
                    <app loc="5"><lem resp="#gallavotti1963 #bravo1980 #CEG #laronde-lefevre2009 #GVCyr #rosamilia2023"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">λ</supplied>υπρ<unclear>ῶ</unclear>ς τάδ' ὁρᾶι</lem>
                        <rdg resp="#SECir"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">ο</supplied>ὐ πρ<supplied reason="lost">ό</supplied>στα δρᾶι</rdg>
                        <rdg resp="#daux1963"><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">ο</supplied>ὐ πρ<choice><corr>ό</corr><sic>ώ</sic></choice>στα δ' <supplied reason="lost">ὁ</supplied>ρᾶι</rdg>
                        <rdg resp="#peek1972"><supplied reason="lost">ὃς δὴ τοῦτο μαθὼν ε</supplied>ὖ πρὸς τάδ' ὁρᾶι</rdg>                        
