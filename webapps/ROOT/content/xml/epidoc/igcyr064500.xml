                    <lb n="1"/><w lemma="βασιλεύς"><supplied reason="lost">Βασιλεὺς</supplied></w> <persName type="ruler" key="Ptolemy IX Soter II"><name nymRef="#Πτολεμαῖος"><supplied reason="lost">Πτολε</supplied><milestone unit="fragment" n="a"/><unclear>μ</unclear>αῖος</name>
