                    <p><app loc="1"><lem resp="#bacchielli1994"><supplied reason="lost">Πρ</supplied>αξιά<supplied reason="lost">δας Ζ</supplied><unclear>ή</unclear>νιο<supplied reason="lost">ς</supplied></lem>
                        <rdg resp="#gasperini1967a"><supplied reason="lost" cert="low">Πρ</supplied>αξιά<supplied reason="lost" cert="low">δας</supplied> <gap reason="lost" extent="unknown" unit="character"/><orig>ινι</orig><gap reason="lost" extent="unknown" unit="character"/></rdg>
