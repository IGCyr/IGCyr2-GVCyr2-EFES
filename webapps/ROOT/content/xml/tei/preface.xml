                <title xml:lang="en">Epigraphic conventions</title>
                <title xml:lang="it">Convenzioni epigrafiche</title>
                <title xml:lang="fr">Conventions épigraphiques</title>
                <title xml:lang="ar">Epigraphic conventions</title>
            </titleStmt>
            <publicationStmt>
                <authority>...</authority>
                <idno type="filename">Preface</idno>
