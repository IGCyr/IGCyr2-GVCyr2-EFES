                    <bibl><ptr target="#rosamilia2023"/>, p. <citedRange>86</citedRange> (typology), pp. <citedRange>324-325</citedRange>, number 65 (text)</bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                <ab>
                    <lb n="1"/><persName type="divine" ref="#unknown"><name><gap reason="lost" extent="unknown" unit="character"/><certainty locus="name" match=".."/></name></persName> <persName type="divine" ref="#unknown"><name><gap reason="lost" extent="unknown" unit="character"/><seg part="F">ς</seg></name></persName> <persName type="divine" ref="#Apollo"><name nymRef="#Ἀπόλλων">Ἀπόλλωνος</name></persName>, 
                        <persName type="divine" ref="#Aphrodite"><name nymRef="#Ἀφροδίτα">Ἀφροδίτας</name></persName>·
                    <lb n="2"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> <persName type="attested"><name type="patronymic"><gap reason="lost" extent="unknown" unit="character"/></name></persName></persName> <rs type="office" key="eponymous priest"><w lemma="ἱαριτεύω"><supplied reason="lost">ἱαρ</supplied>ιτεύων</w></rs> τὸς <w lemma="βωμός">βωμὸς</w> <w lemma="ἐπιγράφω">ἐπέγραψε</w>.

	 </ab>
