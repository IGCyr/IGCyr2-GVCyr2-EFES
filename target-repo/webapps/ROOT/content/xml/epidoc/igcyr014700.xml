                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p><material>Marble</material> <objectType>stele</objectType> with a plain cornice above, sawn off below, so that
                                        its proportions resemble that of a base
                                        (<dimensions>
                                            <width>0.72</width>
                                            <height>0.25</height>
                                            <depth>0.14</depth>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on the cornice (textpart a) and on the face (side 1) below it (textparts b-c, <dimensions>
                                    <width>0.685</width>
                                    <height>0.12</height>
                                    <depth>0.125</depth>
                                </dimensions>): one line (b) written on the whole width;
                                    from line 3 on (c): 4 columns written stoichedon; there are also faint remains of 8 lines on left side (side 2, stextpart d).</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>Lines 1-2 <height>0.01</height>; lines 3 and followings <height>0.007</height>; dotted theta, rho with angular loop, slanting mu and sigma, dissymetrical nu, xi with axial hasta, 
                            very small and open omega.</handNote>
                        </handDesc>
                    </physDesc>
