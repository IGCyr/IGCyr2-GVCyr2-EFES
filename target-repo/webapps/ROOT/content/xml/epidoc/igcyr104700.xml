                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>White <material>marble</material> circular <objectType>base</objectType>, slightly slantering, with a hollow (diameter 0.07) 
                                        on top, which is partly broken off opposite the inscribed section
                                        (height 0.205; diameter 0.15-0.17).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> in three lines on the vertical surface 
                                    (<dimensions>
                                        <width>0.15</width>
                                        <height>0.065</height>
                                        <depth/>
                                    </dimensions>),
                                at <dim type="distance">0.04</dim> from the upper edge; all three lines are aligned at left.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.015</height>; with serifs; theta with central short bar, strokes of lambda and mu slightly curved, smaller omicron, widely open upsilon, 
                                phi with oval small loop.</handNote>
                        </handDesc>
                    </physDesc>
