            </div><div type="apparatus" xml:space="preserve">
            
                <p>
                    <app loc="a.1"><lem resp="#CEG #cdl2000">Εἰρήνηι καὶ Ἐν<supplied reason="lost">υαλίωι</supplied></lem>
                        <rdg resp="#oliverioDAI1">εἰρήνηι κ<subst><del rend="corrected">ι</del><add place="overstrike">α</add></subst>ὶ ἐν <supplied reason="lost" cert="low">πολέμωι</supplied></rdg>
                        <rdg resp="#ghislanzoni1927">Εἰρήνηι καὶ Ἐν<supplied reason="lost">δυμίωνι</supplied></rdg>
                            <rdg resp="#ghislanzoni1927">Εἰρήνηι καὶ Ἐν<supplied reason="lost">υοῖ</supplied></rdg>
                            <rdg resp="#ghislanzoni1927">Εἰρήνηι καὶ Ἐν<supplied reason="lost">νοίαι</supplied></rdg>
                            <rdg resp="#ghislanzoni1927">Εἰρήνηι καὶ Ἐν<supplied reason="lost">οδίαι</supplied></rdg>
                        <rdg resp="#ferri1927c"> Εἰρήνηι καὶ Ἐν<supplied reason="lost">υοῖ</supplied></rdg>  
                            <rdg resp="#ferri1927c">Εἰρήνηι καὶ Ἐν<supplied reason="lost">υαλίωι</supplied></rdg>
                        <rdg resp="#stucchi1987"><supplied reason="lost">Ἐν</supplied> δὲ καὶ εἰρήνηι καὶ ἐν <supplied reason="lost">πολέμωι ἥρωες καὶ ἡρῷσσαι ἐγγένεις ἐπηκόοι</supplied></rdg>
                    </app>
                    <app loc="a.1"><lem resp="#ferri1927c"><supplied reason="lost">ἀνέθηκαν</supplied></lem>
                        <rdg resp="#CEG"><supplied reason="lost" cert="low">μ' ἀνέθηκαν</supplied></rdg> 
                        <rdg resp="#ghislanzoni1927 #oliverioDAI1"><gap reason="lost" extent="unknown" unit="character"/></rdg>
