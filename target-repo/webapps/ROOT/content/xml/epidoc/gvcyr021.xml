                            κ<subst><del rend="corrected">ι</del><add place="overstrike">α</add></subst>ὶ <persName type="divine" ref="#Enyalios"><name nymRef="#Ἐνυάλιος">Ἐν<supplied reason="lost">υαλίωι</supplied></name></persName> <supplied reason="lost">ἀνέθηκαν</supplied></l>
