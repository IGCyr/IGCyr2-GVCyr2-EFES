                    <lb n="2"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65309"><name type="patronymic" nymRef="#Πίθακος">Πιθάκω</name></persName></persName>
	 </ab>
