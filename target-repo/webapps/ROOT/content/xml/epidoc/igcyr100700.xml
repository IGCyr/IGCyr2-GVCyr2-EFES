                        <rdg resp="#cdlBE"><supplied reason="lost">νεὰς</supplied> <note><bibl><ptr target="#cdlBE"/>, <citedRange>1989.832</citedRange></bibl></note></rdg>
                        <rdg resp="#marengo1987"><supplied reason="lost">τὰς</supplied></rdg>
