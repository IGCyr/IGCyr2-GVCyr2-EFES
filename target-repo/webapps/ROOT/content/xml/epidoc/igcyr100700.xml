                    <lb n="4"/><num type="cardinal" value="80"><w><supplied reason="lost">ὀγδ</supplied>οήκοντα</w></num>
                    <lb n="5"/><persName type="divine" ref="#Hermes"><name nymRef="Ἑρμᾶς"><supplied reason="lost">Ἑρμᾶ</supplied>ι</name></persName> <space quantity="1" unit="character"/> 
                    <persName type="divine" ref="#Heracles"><name nymRef="Ἡρακλῆς">Ἡρακλε<supplied reason="lost">ῖ</supplied></name></persName>

	 </ab>
