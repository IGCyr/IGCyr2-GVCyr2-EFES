                <p>
                    <app loc="1">
                        <lem><gap reason="lost" atLeast="1" atMost="2" unit="character"/><unclear>υ</unclear>σανίου</lem>
                           <rdg resp="#jmr-jbwp1952 #IRT2009 #IRT2021"><supplied reason="lost">Πα</supplied>υσανίου</rdg>
                           <rdg resp="#jmr-jbwp1952 #IRT2009 #IRT2021"><supplied reason="lost">Λ</supplied>υσανίου</rdg>
                       <rdg resp="#SECir"><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-65282"><name><supplied reason="lost">Πα</supplied><unclear>υ</unclear>σανίου</name></persName></rdg>
