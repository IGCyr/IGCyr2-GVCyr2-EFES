                    <rdg resp="#jmr1960"><gap reason="lost" extent="unknown" unit="character"/><orig>χων<unclear>λο</unclear></orig><gap reason="lost" quantity="5" unit="character"/><orig>ονα</orig><gap reason="lost" quantity="4" unit="character"/><orig>α</orig><gap reason="lost" quantity="2" unit="character"/>
