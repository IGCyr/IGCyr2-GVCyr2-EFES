                  <w lemma="ὅς1" type="relative">ἃς</w> <w lemma="πρίν">π<unclear>ρ</unclear>ὶν</w> <w lemma="ῥέζω">ἔ<unclear>ρ</unclear>ε<supplied reason="lost">ξεν</supplied></w></l>
