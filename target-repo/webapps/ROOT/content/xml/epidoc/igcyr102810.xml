                        <origin>
                            <origPlace>Findspot.</origPlace>
                            <origDate evidence="lettering" notBefore="-0250" notAfter="-0151" precision="low" cert="low">Perhaps second half of third or first half of second century BC</origDate>
                        </origin>
                        
                            
                                <provenance type="found" notBefore="1929" notAfter="1930">
                                    <p>Found in 1929 or 1930 at 
                                        <placeName type="ancientFindspot" ref="https://www.slsgazetteer.org/909" key="http://pleiades.stoa.org/places/373778">Cyrene</placeName>:
                                        in the <rs type="monuList" ref="https://www.slsgazetteer.org/1228">Sanctuary of Apollo</rs>, West of the <rs type="monuList" ref="https://www.slsgazetteer.org/1042">Strategeion</rs>, in the so-called 
                                        <rs type="monuList" ref="https://www.slsgazetteer.org/1366">Agora of the Gods</rs>.</p>
                                </provenance>
                                <provenance type="observed" resp="morelli" when="1960">
