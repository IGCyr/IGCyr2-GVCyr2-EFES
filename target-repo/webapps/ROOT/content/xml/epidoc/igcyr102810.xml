                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p><material>Limestone</material> <objectType>altar</objectType> made of two adjacent blocks (a and b) with two compartments each; compartment 1 (block a, left)
                                         has been broken off and the compartment 4 (block b, right) is much worn out
                                        (<dimensions>
                                            <width>0.61</width>
                                            <height>0.185</height>
                                            <depth>0.38</depth>
                                        </dimensions> as from ed. princ., are obviously the dimensions of block b only).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed </rs> on the front face in correspondence with the compartments 1, 3 and 4, whereas the surface is 
                                    too badly damaged to read anything relating to compartment 2.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>Compartment 3 <height>0.026</height>; compartment 4 <height>0.03</height>.</handNote>
                        </handDesc>
                    </physDesc>
