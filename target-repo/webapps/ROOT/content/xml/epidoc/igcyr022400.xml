        <body><div type="bibliography">
                
                <p>
                    <bibl><ptr target="#oliverio1930"/>, p. 144, n. <citedRange>1</citedRange> (ph.)</bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>9.147</citedRange></bibl>;
                    <bibl><ptr target="#laronde1987"/>, pp. <citedRange>108-116</citedRange></bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>38.1894</citedRange></bibl>;
                    <bibl><ptr target="#IGCyr"/> <citedRange>022400</citedRange></bibl>;
                    <bibl><ptr target="#rosamilia2023"/>, pp. <citedRange>83-85</citedRange> (monument),  pp. <citedRange>196-197</citedRange> (typology), pp. <citedRange>373-374</citedRange>, number 100 (text)</bibl>.
                    Cf. <bibl><ptr target="#ghislanzoni1925"/>, p. <citedRange>414</citedRange></bibl>;
                    <bibl><ptr target="#oliverio1927"/>, p. <citedRange>326</citedRange></bibl>;
                    <bibl><ptr target="#pernier1935"/>, pp. <citedRange>94-95</citedRange></bibl>;
                    <bibl><ptr target="#robert1955"/>, p. <citedRange>28</citedRange></bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>14.890</citedRange></bibl>;
                    <bibl><ptr target="#stucchi1975"/>, pp. <citedRange>90-92</citedRange>, footnote 3</bibl>;
                    <bibl><ptr target="#cdl2012"/>, pp. <citedRange>245-248</citedRange></bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                <div type="textpart" subtype="column" n="I">
                    <ab>
                        <lb n="1"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name></persName> 
