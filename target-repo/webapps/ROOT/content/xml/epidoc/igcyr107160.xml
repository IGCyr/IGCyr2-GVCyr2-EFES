                <rdg resp="#gasperini1965"><supplied reason="lost">τοὺς ἐκ βασιλέως</supplied> Πτολεμαίω θεῶ <supplied reason="lost">τῶ Εὐεργέτα</supplied></rdg>
                </app>
                <app loc="3-4"><lem><supplied reason="lost">ἐς ἑαυτὸς</supplied> <lb/><space extent="unknown" unit="character"/></lem>                
