                    <lb n="3"/><milestone unit="block" n="i"/><w lemma="ἀρετά"><supplied reason="lost">ἀρετᾶς</supplied></w> <w><supplied reason="lost">ἕν</supplied><milestone unit="block" n="ii"/>εκα</w> καὶ <w lemma="εὐεργεσία">ε<milestone unit="block" n="iii"/><supplied reason="lost">ὐεργεσί<milestone unit="block" n="iv"/>ας</supplied></w> <supplied reason="lost">τᾶς</supplied> <w><supplied reason="lost">ἐ<milestone unit="block" n="v"/>ς</supplied></w> <w lemma="ἑαυτῶ"><supplied reason="lost">ἑαυτὸς</supplied></w>
