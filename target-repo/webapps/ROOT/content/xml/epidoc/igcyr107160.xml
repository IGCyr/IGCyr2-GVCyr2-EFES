                    <lb n="2"/><milestone unit="block" n="i"/><supplied reason="lost">τὸς</supplied> <w><supplied reason="lost">ἐκ</supplied></w> <persName type="ruler" key="Ptolemy VIII and Cleopatra III"><w lemma="βασιλεύς"><supplied reason="lost">βασιλεῦς</supplied></w> 
                    <milestone unit="block" n="ii"/><persName type="ruler" key="Ptolemy VIII"><name nymRef="#Πτολεμαῖος">Πτολεμαίω</name> <rs type="epithet" key="Theos Euergetes"><w lemma="θεός">θεῶ</w> <milestone unit="block" n="iii"/><w lemma="εὐεργέτας"><supplied reason="lost">Εὐεργέτα</supplied></w></rs></persName> <supplied reason="lost">καὶ</supplied> 
