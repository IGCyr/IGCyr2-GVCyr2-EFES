                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>White medium-grained <material>marble</material> rectangular <objectType>base</objectType> with three dowel holes on top, two of them still containing
                                        metal tenons; damaged at all corners and a piece (<dimensions> <width>0.10</width><height>0.21</height><depth>0.065</depth></dimensions>) chiselled away at the lefthand front side;
                                        inscribed front side 
                                        (<dimensions>
                                            <width>0.75</width>
                                            <height>0.21</height>
                                            <depth>0.55</depth>
                                        </dimensions>) is chipped.</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro"/>The stone was inscribed twice: only two lines of the former inscription (<ref type="inscription" source="#IGCyr2">IGCyr077100</ref>) were kept, the upper section being erased
                                    and re-inscribed as ll. 1-3 of  <ref type="inscription" target="https://ircyr2020.inslib.kcl.ac.uk/en/inscriptions/C.446.html">IRCyr2020 C.446</ref>, during the first century BC; moreover the left rim of the whole 
                                    was lost through ulterior chiselling.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>Line 1 <height>0.025</height>, line 2 <height>0.013</height>; alpha with straight bar, smaller omicron, dissymmetrical pi, rho with very small loop, wide upsilon.</handNote>
                        </handDesc>
                    </physDesc>
