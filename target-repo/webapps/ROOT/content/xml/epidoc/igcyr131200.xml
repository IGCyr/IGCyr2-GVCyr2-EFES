                    <lb n="8"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> 
                        <persName type="attested" key=""><name type="patronymic" nymRef="#Θεύδοτος">Θευδότω</name></persName></persName>                    
                    <lb n="9"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> 
                        <persName type="attested" key=""><name type="patronymic" nymRef="#Δεξίλας">Δεξίλα</name></persName></persName>
                    <lb n="10"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> 
                        <persName type="attested" key=""><name nymRef="#_ιος" type="patronymic"><gap reason="lost" atLeast="4" atMost="5" unit="character"/><seg part="F"><unclear>ίω</unclear></seg></name></persName></persName>                    
