                    <lb n="6"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name>
                        <persName type="attested" key=""><name type="patronymic" nymRef="#Σώδαμος">Σωδάμω</name></persName></persName>
                    <lb n="7"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> 
