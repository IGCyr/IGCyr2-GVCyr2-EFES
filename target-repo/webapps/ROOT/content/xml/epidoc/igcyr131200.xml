                        <persName type="attested" key=""><name nymRef="#Ἀπολλ_" type="patronymic"><seg part="I">Ἀπολλ</seg><gap reason="lost" quantity="6" precision="low" unit="character"/></name></persName></persName>
                    <lb n="2"/><persName type="attested"><name><gap reason="lost" extent="unknown" unit="character"/></name> 
                        <persName type="attested" key=""><name nymRef="#Θευδ_" type="patronymic"><seg part="I">Θευδ</seg><gap reason="lost" quantity="3" precision="low" unit="character"/></name></persName></persName>
