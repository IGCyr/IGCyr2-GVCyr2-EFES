                    <lb n="6"/><w>μέγας</w> <orig><choice><unclear>α</unclear><unclear>λ</unclear></choice>ι</orig><gap reason="lost" extent="unknown" unit="character"/> <w lemma="συμβαίνω"><supplied reason="lost" cert="low">σύμ</supplied><lb n="7" break="no"/>βαν</w> <w>ἐς</w> <w lemma="ὅλος">ὅ<supplied reason="lost">λον</supplied></w> <gap reason="lost" extent="unknown" unit="character"/> <supplied reason="lost" cert="low">τῆι</supplied> <w lemma="πόλις"><supplied reason="lost">πό</supplied><lb n="8" break="no"/>λει</w> τε <orig><unclear>η</unclear></orig><gap reason="lost" extent="unknown" unit="character"/>
