                            <origDate evidence="lettering" notBefore="-0300" notAfter="-0201" precision="medium">Third century BC</origDate>
                        </origin>
                        
                            
                                <provenance type="found" notAfter="1923">
                                    <p>Found before 1923 at <placeName type="ancientFindspot" ref="https://www.slsgazetteer.org/909" key="http://pleiades.stoa.org/places/373778">Cyrene</placeName>: 
                                        under Southern part of <rs type="monuList" ref="https://www.slsgazetteer.org/1227">Byzantine Baths</rs>.
                                   </p>
                                </provenance>
                                <provenance type="observed" when="1982" resp="CDL">
                                    <p>Seen by C. Dobias-Lalou in 1982 in the second room to the east of the vestibule or the <rs type="monuList" ref="https://www.slsgazetteer.org/1227">Byzantine Baths</rs>.</p>
