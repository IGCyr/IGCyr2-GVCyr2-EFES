                    τὸ <w lemma="πᾶς">πὰν</w> <w lemma="ἔσειμι">ἐσιὸν</w> τῶ <w lemma="ἐνιαυτός">ἐνιαυτῶ</w> <expan><abbr><am><g type="drachma">𐅂</g></am></abbr><ex>δραχμαί</ex></expan>
                    <num type="cardinal" value="145"><measure type="currency" unit="drachma"><g type="alphabetic">ρμε</g></measure></num>· 
                <lb n="4"/>τὸ <w lemma="πᾶς">πὰν</w> <w lemma="ἔξειμι">ἐξιὸν</w> τῶ <w lemma="ἐνιαυτός">ἐνιαυτῶ</w>. <space atLeast="6" atMost="8" unit="character"/>.
