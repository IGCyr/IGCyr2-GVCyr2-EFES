                    <lb n="1"/><persName type="attested"><name nymRef="#Νῖκις">Νῖκις</name> <persName type="attested" key=""><name nymRef="#Φ_" type="patronymic"><seg part="I">Φ</seg><gap reason="lost" extent="unknown" unit="character"/></name></persName></persName>
	 </ab>
