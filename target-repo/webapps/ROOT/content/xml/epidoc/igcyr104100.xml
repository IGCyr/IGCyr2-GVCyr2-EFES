                    <lb n="4"/><w lemma="λόγος"><unclear>λό</unclear>γωι</w> καὶ <w lemma="ἔργον">ἔργ<unclear>ω</unclear>ι</w> τᾶ<supplied reason="lost">ς</supplied> <w lemma="ποτί"><supplied reason="lost">ποθ’</supplied></w> <w lemma="ἑαυτῶ"><supplied reason="lost">ἑαυτὸς</supplied></w> <w lemma="φιλοστοργία"><supplied reason="lost">φιλο</supplied><lb n="5" break="no"/><unclear>στορ</unclear>γ̣ίας</w> <space quantity="2" unit="character"/> 
