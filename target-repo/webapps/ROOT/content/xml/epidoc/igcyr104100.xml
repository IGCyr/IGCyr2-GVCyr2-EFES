                        <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-63458"><name type="patronymic" nymRef="#Δαμάτριος">Δαμ<supplied reason="lost">ατρίω</supplied></name></persName></persName>, 
