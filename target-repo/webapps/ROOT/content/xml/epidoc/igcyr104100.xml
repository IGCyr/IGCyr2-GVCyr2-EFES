                    <lb n="2"/><w lemma="βασιλεύω">βασιλεύσαντος</w> <persName type="ruler" key="Ptolemy undetermined"><name nymRef="#Πτολεμαῖος">Π<supplied reason="lost">τολεμαίω</supplied></name></persName>, 
