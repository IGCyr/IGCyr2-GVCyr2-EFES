                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>White <material>marble</material>, plain rectangular <objectType>base</objectType>; the base was later reused twice : 1) upside down for a statue with
                                        two footholes on the upper face; 2) recut so that the footholes are at the edge of the new block and a part of the first inscription is lost;
                                        on the upper side of the preserved part, there is a large and deep hole for attachment
                                        (<dimensions>
                                            <width>0.418</width>
                                            <height>0.256</height>
                                            <depth>0.66</depth>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on front face.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.022</height>; light serifs, alpha with rather low bar, beta with larger lower loop, kappa with long oblique bars, non slanting sigma.</handNote>
                        </handDesc>
                    </physDesc>
