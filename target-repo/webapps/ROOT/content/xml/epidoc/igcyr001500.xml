                    <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/><persName type="attested" key=""><name nymRef="#_ος"><seg part="F">ος</seg></name> <g type="punct">:</g> <persName type="attested" key=""><name type="patronymic" nymRef="#Εὔμολπος">hὀυμόλ<unclear>π</unclear><supplied reason="lost">ō</supplied></name></persName></persName>
                            <gap reason="lost" extent="unknown" unit="character"/>
	 </ab>
