                        <ab>
                        <lb n="1"/><date calendar="cyrenaean" xml:id="ActiumEra"><supplied reason="lost"><expan><abbr><am><g type="year">𐅹</g></am></abbr> <ex>ἔτους</ex></expan></supplied> 
                        <num type="ordinal" value="229">
                            <supplied reason="lost"><g type="alphabetic">σ</g></supplied><g type="alphabetic">κθ</g></num></date>
                        <persName type="attested" key=""><name type="parenomen" nymRef="#Τιβέριος"><expan><abbr>Τι</abbr><ex>βέριος</ex></expan></name> <name type="nomen" nymRef="#Πετρώνιος">Πετρώνιος</name>
                        <lb n="2"/><name type="cognomen" nymRef="#Καπίτων">Καπίτων</name></persName> <date dur="P24Y"><w lemma="ἔτος">ἐτῶν</w>
                        <num type="cardinal" value="24">
