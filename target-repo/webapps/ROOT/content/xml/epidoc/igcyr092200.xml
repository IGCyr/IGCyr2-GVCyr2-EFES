        <body><div type="bibliography">
                
                <p><bibl><ptr target="#paci2003"/>, pp. 180-181, n. <citedRange>4</citedRange> (ph.)</bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>53.2053, 4</citedRange></bibl>;
