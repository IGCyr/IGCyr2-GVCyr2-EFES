                   <ab>
                    <lb n="5"/><persName type="attested"><name nymRef="#_ιλέα"><gap reason="lost" extent="unknown" unit="character"/><seg part="F">ιλέα</seg></name>                    
                    <lb n="6"/><persName type="attested"><name nymRef="#_ιππος" type="patronymic"><gap reason="lost" extent="unknown" unit="character"/><seg part="F"><supplied reason="lost">ί</supplied><unclear>π</unclear>πω</seg></name></persName></persName>
                    </ab>
               </div></div>
