                    <bibl><ptr target="#IGCyr"/> <citedRange>095150</citedRange></bibl>. 
                    Cf. <bibl><ptr target="#cdl2003a"/>, pp. <citedRange>211-216</citedRange></bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>53.2049</citedRange></bibl>; 
                    <bibl><ptr target="#marengo2007"/><citedRange/></bibl>, whence 
                    <bibl><ptr target="#SEG"/>, <citedRange>57.1997</citedRange></bibl>;
                    <bibl><ptr target="#rosamilia2023"/>, p. <citedRange>106</citedRange> (prosopography), p. <citedRange>370</citedRange>, number 96 (text)</bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                       
                            <ab>
                                <lb n="1"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-62845"><name nymRef="#Ἀναξιλέα">Ἀναξιλέα</name></persName> <gap reason="lost" extent="unknown" unit="character"/> 
                                <lb n="2"/><rs type="office" key="priestess"><w lemma="συνιαριτεύω">συνιαρειτεύο<supplied reason="lost">ισα</supplied></w></rs> <w lemma="σύν"><supplied reason="lost">σὺν</supplied></w> 
                                <lb n="3"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-62577"><name nymRef="Ἁγησίστρατος">Ἁγησιστράτωι</name> 
                                    <persName type="attested" key=""><name nymRef="#Πο_"><seg part="I">Πο</seg></name></persName></persName><gap reason="lost" quantity="6" unit="character" precision="low"/>                            
                                <lb n="4"/><w lemma="φιάλα">φιάλαν</w> <w lemma="ἀνατίθημι">ἀνέθηκε</w> <num type="total" value="100"><measure type="currency" unit="Alexander'sdrachma"><w lemma="ἀργύριον"><supplied reason="lost">ἀργυρίω</supplied></w>
                                <lb n="5"/><w lemma="Ἀλεξάνδρειος">Ἀλεξανδρείω</w> <w lemma="δραχμά">δ<supplied reason="lost">ραχμᾶν</supplied></w> <num type="total" value="100"><supplied reason="lost" cert="low"><g type="alphabetic">ρ</g></supplied></num></measure></num>
                              </ab>
            </div><div type="apparatus" xml:space="preserve">
            
                <p>
                    <app loc="2">
                        <lem resp="#IGCyr"><supplied reason="lost">σὺν</supplied></lem>
