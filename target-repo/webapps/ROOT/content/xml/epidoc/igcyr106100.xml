                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>Fragmentary white <material>marble</material> circular <objectType>base</objectType>, broken off at right, left, back and below; 
                                        a plain moulding divides the inscribed area and a relief featuring at left a figure carrying a lyre, at right a head with a crested helmet; 
                                        (<dimensions>
                                            <width>0.135</width>
                                            <height>0.09</height>
                                            <depth>unknown</depth>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on top member of the moulding.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.013</height>; deeply but not so carefully cut; no serifs, very small loop of rho, widely open upsilon.</handNote>
                        </handDesc>
                    </physDesc>
