                        <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-60865"><name nymRef="#Διονύσιος" type="patronymic">Διονυσίου</name></persName></persName>
	 </ab>
