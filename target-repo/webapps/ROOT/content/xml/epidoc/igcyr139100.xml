                    <lb n="2"/><persName type="attested" key=""><name><gap reason="lost" extent="unknown" unit="character"/></name> <persName type="attested" key=""><name type="patronymic" nymRef="#Φίλισκος"><supplied reason="lost">Φ</supplied>ιλίσ<supplied reason="lost" cert="low">κω</supplied></name></persName></persName>
