                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>Rectangular <objectType>altar</objectType> cut in the <material>rock</material>, surrounded by a regular margin and originally separated in two unequal parts;
                                        a deep transversal trench cutting the rectangle in the middle of the width might be a pit for libations
                                        (whole altar <dimensions>
                                            <width>0.96</width>
                                            <height>0.46</height>
                                        </dimensions>; inscribed margin
                                        <dimensions>
                                            <width>0.96</width>
                                            <height>0.06</height>
                                        </dimensions>).
                                    </p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on the upper border; many later Greek and Arabic letters were scratched everywhere.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height>0.04</height>; epsilon with oblique bars, rho with large loop not quite circular.</handNote>
                        </handDesc>
                    </physDesc>
