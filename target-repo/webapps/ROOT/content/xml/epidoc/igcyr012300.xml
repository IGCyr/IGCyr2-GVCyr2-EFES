                    </app>
                    <app loc="3"><lem resp="#IGCyr"><supplied reason="lost">Ἀ</supplied>θαναίας ἱαρέα<supplied reason="lost">ι</supplied> <supplied reason="lost" cert="low">τροφά</supplied> <note><supplied reason="lost">τροφᾶς</supplied> is also possible</note></lem>                    
                    <rdg resp="#rosamilia2023"><supplied reason="lost">Ἀ</supplied>θαναίας ἱαρέα<supplied reason="lost">ι</supplied> <gap reason="lost" extent="unknown" unit="character"/>/&gt;</rdg>
                    </app>
