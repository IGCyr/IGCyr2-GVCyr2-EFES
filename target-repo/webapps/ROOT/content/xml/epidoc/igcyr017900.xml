                    <lb n="1"/><milestone unit="fragment" n="a"/><persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-66108"><name nymRef="#Φίλων">Φ<supplied reason="lost">ί</supplied><milestone unit="fragment" n="b"/><unclear>λ</unclear>ων</name> 
                        <persName type="attested" key="http://clas-lgpn2.classics.ox.ac.uk/cgi-bin/lgpn_search.cgi?id=V1-62907"><name nymRef="#Αννικερις" type="patronymic">Αννικεριο<milestone unit="fragment" n="c"/><supplied reason="lost">ς</supplied></name></persName></persName>
                    <lb n="2"/><milestone unit="fragment" n="a"/>τὸ<supplied reason="lost">ν</supplied> <w lemma="βωμός"><supplied reason="lost">β</supplied><milestone unit="fragment" n="b"/>ωμὸν</w> 
                    <w lemma="ἀνατίθημι">ἀνέθηκε</w> τὸν <w lemma="λύγδινος">λύγ<unclear>δ</unclear><milestone unit="fragment" n="c"/><supplied reason="lost">ινο</supplied>ν</w>
	 </ab>
