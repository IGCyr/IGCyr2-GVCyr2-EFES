        <body><div type="bibliography">
                
            <p>Not published before <bibl><ptr target="#IGCyr"/> <citedRange>132700</citedRange></bibl>, whence 
                    <bibl><ptr target="#SEG"/> <citedRange>67.1501</citedRange></bibl>.</p>
            </div><div type="edition" xml:lang="grc" xml:space="preserve">
                
                <div type="textpart" subtype="column" n="a">
                    <ab>
                    <lb n="0"/><gap reason="lost" extent="unknown" unit="line"/>
                    <lb n="1"/><handShift new="#m1"/><persName type="attested" key=""><name nymRef="#Ἀριστοτέλης"><supplied reason="lost">Ἀριστ</supplied>οτέλης</name> 
                        <persName type="attested" key=""><name type="patronymic" nymRef="#Μενέστρατος">Μενεστράτω</name></persName></persName>
                    <lb n="2"/><persName type="attested" key=""><name nymRef="#Καρνηάδας"><supplied reason="lost">Καρν</supplied>ηάδας</name> 
                        <persName type="attested" key=""><name nymRef="#Ἅδυλις">Ἁδύλιος</name></persName></persName>
                    <lb n="3"/><persName type="attested" key=""><name nymRef="#Πολυάρατος"><supplied reason="lost">Πολυ</supplied>άρατος</name>
                        <persName type="attested" key=""><name type="patronymic" nymRef="#Εὐφρίας">Εὐφρία</name></persName></persName>
