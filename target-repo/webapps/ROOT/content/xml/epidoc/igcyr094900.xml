            </div><div type="apparatus" xml:space="preserve">
            
                <p>
                    <app loc="a.2"><lem><gap reason="lost" extent="unknown" unit="character"/><unclear>λ</unclear>ω</lem>
                                <rdg resp="#SECir"><gap reason="lost" extent="unknown" unit="character"/>ω</rdg></app>
                    <app loc="a.10"> <note>the letter was seen by Oliverio but is now lost</note></app>
                    <app loc="b.1"><lem>Κ<unclear>αρνή</unclear><supplied reason="lost">δας</supplied><gap reason="lost" extent="unknown" unit="character"/></lem>
