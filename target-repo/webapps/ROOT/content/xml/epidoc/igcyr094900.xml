                    <app loc="b.4"><lem>Βαλι<supplied reason="lost">ς</supplied></lem>
                                <rdg resp="#SECir">Βαλι<gap reason="lost" extent="unknown" unit="character"/></rdg></app>
                    <app loc="b.6"><lem>Ἀντέρο<unclear>τ</unclear><supplied reason="lost" cert="low">ις</supplied></lem>
