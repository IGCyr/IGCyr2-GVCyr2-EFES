                 <rdg resp="#oliverioDAI1 #IGCyr"><supplied reason="lost">μαλακᾶν</supplied> <gap reason="lost" extent="unknown" unit="character"/> <lb/><gap reason="lost" extent="unknown" unit="character"/></rdg>
