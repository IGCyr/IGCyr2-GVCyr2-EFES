                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>White <material>marble</material> tapering <objectType>stele</objectType>, chipped at top and broken off (or cut off ?) at the right upper angle; 
                                        a wreath is sculpted high on front face
                                        (<dimensions>
                                            <width min="0.36" max="0.42">0.36 to 0.42</width>
                                            <height>1.25</height>
                                            <depth min="0.27" max="0.32">0.27-0.32</depth>
                                        </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout>L. 2 is <rs type="execution" key="scalpro">inscribed</rs> in the middle of the wreath (diameter 0.14) and wholly inside it 
                                    at line 2, while l. 1 has its first letter beyond the limits of the wreath.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote><height atLeast="0.02" atMost="0.025">0.02-0.025</height>.</handNote>
                        </handDesc>
                    </physDesc>
