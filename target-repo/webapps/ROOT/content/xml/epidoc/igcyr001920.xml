                <p>
                    <app loc="1"><lem resp="#marengo2010b">Ἀρχένβ<unclear>ρ</unclear><supplied reason="lost">οτ</supplied> <gap reason="lost" atLeast="1" atMost="2" unit="character"/></lem>
