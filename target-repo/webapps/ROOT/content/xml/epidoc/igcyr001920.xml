                        <rdg resp="#boardman-hayes1966"><orig>αρψηνβ<unclear>α</unclear></orig></rdg>
                        <rdg resp="#boardman-hayes1966">Αρχην Β<unclear>α</unclear><supplied reason="lost" cert="low">καλ</supplied> <note>Anna Morpurgo Davies' suggestion</note></rdg>
