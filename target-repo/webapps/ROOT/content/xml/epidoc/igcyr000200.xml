    <text>
        <body><div type="bibliography">
                
                <p><bibl><ptr target="#boardman1966"/>, p. 151, n. <citedRange>14</citedRange></bibl>;
               <bibl><ptr target="#cdl1970"/>, p. <citedRange>251, c</citedRange></bibl>;
