            <sourceDesc>
                <msDesc>
                    <msIdentifier><repository>Cyrene Museum</repository> <idno type="invNo">180+1001+190</idno></msIdentifier>
                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>Three non-adjacent fragments of a white <material>marble</material> <objectType>panel</objectType> of which the left part is lost;
                                        at back, a margin with lesser depth was probably intended for inserting the panel into a wall or monument;
                                        fragment a (inv. 180), broken off above, below and at left (<dimensions>
                                            <width atMost="0.215">0.215</width>
                                            <height atMost="0.175">0.175</height>
                                            <depth min="0.04" max="0.05">0.04-0.05</depth>
                                        </dimensions>); 
                                        fragment b (inv. 1001) broken off on all four sides (<dimensions>
                                            <width atMost="0.14">0.14</width>
                                            <height atMost="0.125">0.125</height>
                                            <depth>0.05</depth>
                                        </dimensions>);
                                        fragment c (inv. 190) broken off above, at left and right, but keeping a very small part of the lower right angle (<dimensions>
                                        <width atLeast="0.13">0.13</width>
                                        <height atLeast="0.16">0.16</height>
                                        <depth>0.05</depth>
                                    </dimensions>).</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on the face with at least 20 to 24 lines of verse (one line per verse, leaving larger spaces 
                                    at the end of the pentameters and also a space between the two hemistichs of the same); ending with 1 line of text.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>Verse: <height>0.08</height>; last line <height>0.01</height>; very carefully cut, with large serifs; alpha rather narrow with straight bar,
                                beta with larger lower loop, spool-shaped zeta, theta wit central short bar, xi with three independent bars, slightly smaller round letters,
                                non-slanting sigma, phi with flattened loop.</handNote>
                        </handDesc>
                    </physDesc>
                    
                    <history>
                        <origin>
                            <origPlace>Findspot.</origPlace>
                            <origDate evidence="lettering" notBefore="-0075" notAfter="-0015" precision="medium">First century BC, preferably Augustan</origDate>
                        </origin>
                        
                        
                        <provenance type="found" when="1916">
                            <p>Fragment a was found in 1916 by E. Ghislanzoni at 
                                <placeName type="ancientFindspot" ref="https://www.slsgazetteer.org/909" key="http://pleiades.stoa.org/places/373778">Cyrene</placeName>: 
                                 on the North side  of the <rs type="monuList" ref="https://www.slsgazetteer.org/1016">Acropolis</rs>, in the 
                                <rs type="monuList" ref="https://www.slsgazetteer.org/1020">Iseum</rs>. The two other fragments were plausibly found in the same area in 1935.</p>
                            
                        </provenance>
                        <provenance type="observed" when="1977" when-iso="1979" resp="CDL">
                            <p>Seen by C. Dobias-Lalou in 1977 (fragment b) and 1979 (fragments a and c) in <placeName type="modernSpot" ref="http://www.geonames.org/8410832" key="Shahat">Shahat</placeName>: 
                            <rs type="monuList" ref="https://www.slsgazetteer.org/933">Cyrene Museum</rs></p>.
                        </provenance>
                    </history>
                </msDesc>
