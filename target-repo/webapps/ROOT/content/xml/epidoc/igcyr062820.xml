                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support>
                                    <p>Two adjacent fragments of a white <material>marble</material> <objectType>pillar</objectType> broken on top, below and in the middle, 
                                        which bore also <ref type="inscription" source="#IGCyr2">IGCyr062800</ref>, <ref type="inscription" source="#IGCyr2">IGCyr062810</ref>, <ref type="inscription" source="#IGCyr2">IGCyr062830</ref>,  
                                        <ref type="inscription" source="#IGCyr2">IGCyr062840</ref> and <ref type="inscription" source="#IGCyr2">IGCyr062850</ref>; ; <ref type="inscription" source="#IGCyr2">IGCyr097600</ref> is probably the upper part of the pillar;
                                        <ref type="inscription" source="#IGCyr2">IGCyr097150</ref> might also belong to the collection.
                                         Fragment a (<dimensions>
                                            <width>0.20</width>
                                            <height>0.11</height>
                                            <depth>0.25</depth>
                                        </dimensions>) keeps the left edge of the face; fragment b
                                        (<dimensions>
                                            <width>0.09</width>
                                            <height>0.20</height>
                                            <depth>0.15</depth>
                                        </dimensions>) keeps the right edge of the face.</p>
                                </support>
                            </supportDesc>
                            <layoutDesc>
                                <layout><rs type="execution" key="scalpro">Inscribed</rs> on the side to the right of <ref type="inscription" source="#IGCyr2">IGCyr062800</ref> and 
                                <ref type="inscription" source="#IGCyr2">IGCyr062810</ref>; fragment a has been recut on top, so that the letters of line 1 are curtailed; both fragments 
                                    are joining below at the level of <ref type="inscription" source="#IGCyr2">IGCyr062830</ref>, but do not provide a complete line for the present inscription.</layout>
                            </layoutDesc>
